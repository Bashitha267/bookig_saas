
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  firstName    String
  lastName     String
  nicNumber    String?  // Not required
  contact      String
  whatsapp     String
  address      String
  role         Role
  password     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  ownerId      Int?     // For staff, reference to owner
  owner        User?    @relation("OwnerStaff", fields: [ownerId], references: [id])
  staff        User[]   @relation("OwnerStaff")
}

enum Role {
  admin
  owner
  staff
}
